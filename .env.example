# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://gamesignal_app:localdev@localhost:5432/gamesignal
# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# ── Steam ─────────────────────────────────────────────────
STEAM_API_KEY=여기에_Steam_API_키_입력
# 발급: https://steamcommunity.com/dev/apikey
# ── YouTube Data API v3 ───────────────────────────────────
YOUTUBE_API_KEYS=["키1","키2"]
YOUTUBE_QUOTA_LIMIT=10000
YOUTUBE_QUOTA_LOW_WATER=200
# ── Slack ─────────────────────────────────────────────────
SLACK_WEBHOOK_PIPELINE=여기에_Slack_웹훅_URL
SLACK_WEBHOOK_ALERT=여기에_Slack_웹훅_URL
# ── App ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
# ── Pipeline ──────────────────────────────────────────────
PIPELINE_TIMEOUT_MS=3600000
RETRY_MAX=3
RETRY_BASE_MS=1000
SCRAPE_DELAY_MIN_MS=3000
SCRAPE_DELAY_MAX_MS=5000
BLOCK_WAIT_MS=900000
